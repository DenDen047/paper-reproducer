{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DenDen047/paper-reproducer/schemas/analysis.schema.json",
  "title": "analysis.json (Phase 1 出力)",
  "description": "重要な invariant のみを enforce する。新規フィールド追加は許可 (additionalProperties: true)。",
  "type": "object",
  "required": ["repo_name", "repo_url", "dep_type", "feasibility", "reproduction_mode", "paper_claims"],
  "properties": {
    "repo_name":  { "type": "string", "minLength": 1 },
    "repo_url":   { "type": "string", "minLength": 1 },
    "github_slug": { "type": ["string", "null"] },

    "dep_type": {
      "description": "repo-analyzer Step 4 の 6-Type 判定 (A > C > B > E > D > F)。",
      "enum": ["A1", "A2", "A3", "B1", "B2", "B3", "C1", "C2", "C3",
               "D1", "D2", "D3", "E1", "E2", "E3", "F"]
    },

    "pixi_strategy": {
      "type": "object",
      "description": "Phase 2 (pixi-env-builder) が読む環境構築戦略。torch_source は Step 5 で判定。",
      "properties": {
        "defaults_channel_present": { "type": "boolean" },
        "torch_source": { "enum": ["pypi_wheel", "conda_pytorch", null] }
      }
    },

    "dep_files_found": {
      "type": "object",
      "description": "repo-analyzer Step 1 で検出した依存ファイルのパス一覧 (種類別)。cuda-dependency-resolver の条件付き Known issue が参照する。",
      "properties": {
        "environment_yml":  { "type": "array", "items": { "type": "string" } },
        "requirements_txt": { "type": "array", "items": { "type": "string" } },
        "pyproject_toml":   { "type": "array", "items": { "type": "string" } },
        "setup_py":         { "type": "array", "items": { "type": "string" } },
        "dockerfile":       { "type": "array", "items": { "type": "string" } }
      }
    },

    "demo_commands": {
      "type": "array",
      "description": "repo-analyzer Step 6 で特定したデモ/推論コマンド (実行順の候補)。usage-documenter / dep-converter が参照する。",
      "items": { "type": "string", "minLength": 1 }
    },

    "model_download": {
      "type": ["object", "null"],
      "description": "repo-analyzer Step 7 で検出した重み取得方法。Phase 3 Step 1 が参照する。",
      "properties": {
        "method": { "enum": ["wget", "curl", "gdown", "huggingface_hub", "custom_script", "none"] },
        "urls":   { "type": "array", "items": { "type": "string" } },
        "notes":  { "type": ["string", "null"] }
      }
    },

    "feasibility": {
      "type": "object",
      "required": ["status", "blockers"],
      "properties": {
        "status": { "enum": ["ok", "degraded", "infeasible"] },
        "blockers": {
          "type": "array",
          "description": "object 形式で統一 (string とのユニオン禁止)。空配列 OK。",
          "items": {
            "type": "object",
            "required": ["id", "detail"],
            "properties": {
              "id":       { "type": "string", "minLength": 1 },
              "detail":   { "type": "string", "minLength": 1 },
              "severity": { "enum": ["info", "warn", "error"] },
              "recovery": { "type": "string" }
            }
          }
        }
      }
    },

    "reproduction_mode": {
      "enum": ["inference_only", "train_required", "train_optional"]
    },
    "training_recovery": {
      "type": ["object", "null"],
      "properties": {
        "checkpoint_interval_iters": { "type": ["integer", "null"], "minimum": 1 },
        "checkpoint_dir_pattern":    { "type": ["string", "null"] },
        "resume_arg":                { "type": ["string", "null"] }
      }
    },

    "paper_claims": {
      "type": "array",
      "description": "論文 Table N の claim を抽出。空配列なら claims_extraction.status を必須とする (allOf で強制)。",
      "items": {
        "type": "object",
        "required": ["id", "metric_name", "paper_target", "tolerance", "claim_source"],
        "properties": {
          "id":            { "type": "string", "minLength": 1 },
          "metric_name":   { "type": "string", "minLength": 1 },
          "paper_target":  { "type": "number" },
          "tolerance":     { "type": "string", "minLength": 1 },
          "claim_source":  { "type": "string", "minLength": 1 }
        }
      }
    },

    "claims_extraction": {
      "type": "object",
      "description": "paper_claims が空の理由を明示するメタ情報。空でも非空でも常に書く。",
      "required": ["status"],
      "properties": {
        "status": {
          "enum": ["extracted", "no_quantitative_claims", "paper_unavailable", "extraction_failed"]
        },
        "evidence": { "type": ["string", "null"] }
      }
    },

    "data_acquisition_table": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "category", "required_for_claims"],
        "properties": {
          "name":     { "type": "string", "minLength": 1 },
          "url":      { "type": ["string", "null"] },
          "size_gb_estimated":   { "type": ["number", "null"], "minimum": 0 },
          "size_gb_probed":      { "type": ["number", "null"], "minimum": 0 },
          "category": { "enum": ["bundled", "auto-fetch", "assisted", "gated", "blocked"] },
          "required_for_claims": {
            "type": "array",
            "items": { "type": "string" }
          },
          "preprocess": { "enum": ["none", "repo_script", "external_tool"] },
          "disk_after_extract_gb": { "type": ["number", "null"], "minimum": 0 },
          "probe": {
            "type": ["object", "null"],
            "properties": {
              "method":     { "enum": ["http_head", "gdown_dry_run", "hf_api", "none"] },
              "reachable":  { "type": "boolean" },
              "checked_at": { "type": "string" },
              "evidence":   { "type": "string" }
            }
          }
        }
      }
    },

    "manual_assets": {
      "type": "array",
      "description": "ライセンス登録が必須で自動 DL できない手動 provisioning 資産 (SMPL/SMAL 系等)。repo-analyzer Step 7.7 で検出し、Phase 3 が /manual-assets から repo 期待パスへ配置する。dataset とは別アセットクラス。",
      "items": {
        "type": "object",
        "required": ["display_name", "repo_expected_path", "required_for_claims"],
        "properties": {
          "key":                 { "type": ["string", "null"] },
          "display_name":        { "type": "string", "minLength": 1 },
          "repo_expected_path":  { "type": "string", "minLength": 1 },
          "registry_candidate":  { "type": ["string", "null"] },
          "source_url":          { "type": ["string", "null"] },
          "license_url":         { "type": ["string", "null"] },
          "present_in_registry": { "type": ["boolean", "null"] },
          "detection_evidence":  { "type": ["string", "null"] },
          "required_for_claims": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  },

  "allOf": [
    {
      "description": "paper_claims が空配列なら claims_extraction.status は extracted 以外でなければならない。",
      "if": {
        "properties": { "paper_claims": { "type": "array", "maxItems": 0 } },
        "required": ["paper_claims"]
      },
      "then": {
        "required": ["claims_extraction"],
        "properties": {
          "claims_extraction": {
            "properties": {
              "status": { "enum": ["no_quantitative_claims", "paper_unavailable", "extraction_failed"] }
            },
            "required": ["status"]
          }
        }
      }
    },
    {
      "description": "paper_claims が非空なら claims_extraction.status=extracted で evidence 必須。",
      "if": {
        "properties": { "paper_claims": { "type": "array", "minItems": 1 } },
        "required": ["paper_claims"]
      },
      "then": {
        "required": ["claims_extraction"],
        "properties": {
          "claims_extraction": {
            "properties": {
              "status":   { "const": "extracted" },
              "evidence": { "type": "string", "minLength": 1 }
            },
            "required": ["status", "evidence"]
          }
        }
      }
    },
    {
      "description": "reproduction_mode=train_optional は checkpoint URL が paper_claims を全て eval 可能な前提。training_recovery が null では train_optional を許可しない。",
      "if": {
        "properties": { "reproduction_mode": { "const": "train_optional" } },
        "required": ["reproduction_mode"]
      },
      "then": {
        "required": ["training_recovery"],
        "properties": {
          "training_recovery": { "type": "object" }
        }
      }
    },
    {
      "description": "reproduction_mode=train_required も training_recovery を必須化 (resume 経路を持つこと)。",
      "if": {
        "properties": { "reproduction_mode": { "const": "train_required" } },
        "required": ["reproduction_mode"]
      },
      "then": {
        "required": ["training_recovery"],
        "properties": {
          "training_recovery": { "type": "object" }
        }
      }
    }
  ]
}
